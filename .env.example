# ─────────────────────────────────────────────
# SafeGuard AI — environment configuration
# Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────
#
# Running with Docker Compose? Just do:
#   cp .env.example .env   # edit JWT_SECRET + your AI provider key
#   docker compose up -d   # nothing builds locally; images pull from GHCR
#
# The compose file overrides DATABASE_URL / REDIS_URL with the correct
# container hostnames, so you don't need to touch those.

# --- Datastores ---
# For native cargo run dev (outside Docker): use localhost.
# Docker Compose overrides these automatically from the compose file.
DATABASE_URL=postgres://safeguard:safeguard@localhost:5432/safeguard
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=2592000

# --- Gateway ---
GATEWAY_BIND=0.0.0.0:8080
CONTROL_PLANE_BIND=0.0.0.0:8081

# --- Cloud LLM providers (BYO keys) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_API_KEY=

# --- Self-hosted LLM backends ---
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=

# --- DLP ---
PRESIDIO_URL=http://localhost:5001
DLP_DEEP_SCAN_DEFAULT=false

# --- RAG embeddings (gateway retrieval + control-plane ingest) ---
# Defaults to OPENAI_BASE_URL + OPENAI_API_KEY. Override EMBEDDING_BASE_URL to use
# a self-hosted embedder (e.g. http://localhost:11434 for Ollama, no key needed).
# EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# --- Privacy ---
ZERO_RETENTION_DEFAULT=false

# --- Admin bootstrap (optional, for self-hosted / cloud deployments) ---
# Set ADMIN_EMAIL to auto-create the first admin account on first startup.
# The initial password is generated (or use ADMIN_PASSWORD) and logged to stdout.
# Without ADMIN_EMAIL the registration page works as before (creates a new org + Admin).
#
# For cloud-hosted mode (open registration as User, shared org):
#   CONTROL_PLANE_MODE=cloud
# Then everyone who signs up joins the shared org as a User.
#ADMIN_EMAIL=admin@example.com
#ADMIN_PASSWORD=
#CONTROL_PLANE_MODE=

# --- Logging ---
RUST_LOG=info,gateway=debug,control_plane=debug
